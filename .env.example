# ============================================================
# #NotWaiting — Server Environment Variables
# Copy this to server/.env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# Port the API server runs on (default 3001, frontend runs on 5173)
PORT=3001

# ── Supabase ─────────────────────────────────────────────────
# From: https://supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic Claude ─────────────────────────────────────────
# From: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Admin Dashboard ───────────────────────────────────────────
# Password to access /api/dashboard — change before deploying
DASHBOARD_SECRET=notwaiting2025

# ── Frontend URL (for CORS) ──────────────────────────────────
# In dev this is the Vite dev server. In prod, your deployed domain.
FRONTEND_URL=http://localhost:5173

# ── Admin App URL (for CORS and invite redirect) ──────────────
# Dev: http://localhost:5200
# Production: https://admin.notwaiting.africa
ADMIN_URL=http://localhost:5200

# ── Supabase Anon Key (for validating user JWTs) ─────────────
# From: https://supabase.com → Settings → API → anon public key
SUPABASE_ANON_KEY=your-anon-key-here
